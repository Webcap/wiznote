# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://.supabase.co

# Supabase API Keys (use the new publishable key format for Expo)
EXPO_PUBLIC_SUPABASE_KEY=
# Legacy anon key (NOT NEEDED - legacy keys are disabled on this project)
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-key

# Server-side Secret Key (NEVER commit this! Keep it secret, only use server-side)
# NEW: Use sb_secret_... format (recommended)
SUPABASE_SECRET_KEY=sb_secret_your_secret_key_here
# LEGACY: JWT-based service_role key (still supported but deprecated)
# Only needed if you haven't migrated to secret keys yet
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase Edge Functions (optional - for complete account deletion)
EXPO_PUBLIC_DELETE_ACCOUNT_FUNCTION_URL=https://your-project.supabase.co/functions/v1/delete-user-account

# Better Auth Configuration
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI Services
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Webhook Configuration
EXPO_PUBLIC_WEBHOOK_BASE_URL=https://api.webcap.media/api


# Development Configuration
NODE_ENV=development
DEBUG=true 

# Optional environment variable to control Supabase logging
EXPO_PUBLIC_SUPABASE_LOGS=false

# Optional environment variable to control auth state logs  
EXPO_PUBLIC_AUTH_LOGS=false