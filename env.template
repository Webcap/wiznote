# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://.supabase.co

# Web URL (for password reset links from mobile app)
# Production: https://wiznote.app (your Netlify domain)
# Development: http://localhost:8081 or your dev URL
# Set this in your .env file - use production URL for production builds
EXPO_PUBLIC_WEB_URL=https://wiznote.app

# API URL (for mobile security logging with server-side IP capture)
# Production: https://wiznote.app (your Netlify domain)
# Development: http://localhost:8888 (Netlify Dev)
EXPO_PUBLIC_API_URL=https://wiznote.app

# Supabase API Keys (use the new publishable key format for Expo)
EXPO_PUBLIC_SUPABASE_KEY=
# Legacy anon key (NOT NEEDED - legacy keys are disabled on this project)
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-key

# Server-side Secret Key (NEVER commit this! Keep it secret, only use server-side)
# NEW: Use sb_secret_... format (recommended)
SUPABASE_SECRET_KEY=sb_secret_your_secret_key_here
# LEGACY: JWT-based service_role key (still supported but deprecated)
# Only needed if you haven't migrated to secret keys yet
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase Edge Functions (optional - for complete account deletion)
EXPO_PUBLIC_DELETE_ACCOUNT_FUNCTION_URL=https://your-project.supabase.co/functions/v1/delete-user-account

# Better Auth Configuration
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI Services
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# ========================================
# STRIPE CONFIGURATION
# ========================================
# For DEVELOPMENT: Use TEST keys (pk_test_..., sk_test_...)
# For PRODUCTION: Use LIVE keys (pk_live_..., sk_live_...)
# Get keys from: https://dashboard.stripe.com → Developers → API keys
# ========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here

# ========================================
# STRIPE GUARDIAN CONFIGURATION (DUAL ENVIRONMENT)
# ========================================
# Development/Test: Set this to your Render deployment with TEST Stripe keys
#   Format: https://your-service-name.onrender.com (NO /api suffix)
#   Leave empty to use production Stripe Guardian for testing
# Production: Automatically uses https://api.webcap.media/api (Starlight Hyperlift)
# ========================================
EXPO_PUBLIC_STRIPE_GUARDIAN_TEST_URL=

# Manual override (optional): Force a specific URL for all environments
# EXPO_PUBLIC_WEBHOOK_BASE_URL=https://api.webcap.media/api


# Development Configuration
NODE_ENV=development
DEBUG=true 

# Optional environment variable to control Supabase logging
EXPO_PUBLIC_SUPABASE_LOGS=false

# Optional environment variable to control auth state logs  
EXPO_PUBLIC_AUTH_LOGS=false