  {
    "snackbarDesign": {
      "description": "Web snackbar notification system for user feedback",
      "component": "WebSnackbar",
      "file": "components/web/WebSnackbar.tsx",
      "context": "contexts/SnackbarContext.tsx",
      "types": {
        "success": {
          "backgroundColor": "#3CB371",
          "icon": "checkmark-circle",
          "iconColor": "#FFFFFF",
          "useCase": "Successful operations (create, update, delete)"
        },
        "error": {
          "backgroundColor": "#FF6B6B",
          "icon": "close-circle",
          "iconColor": "#FFFFFF",
          "useCase": "Failed operations, authentication errors"
        },
        "warning": {
          "backgroundColor": "#FF8C00",
          "icon": "warning",
          "iconColor": "#FFFFFF",
          "useCase": "Timeouts, temporary issues, retryable errors"
        },
        "info": {
          "backgroundColor": "#6A5ACD",
          "icon": "information-circle",
          "iconColor": "#FFFFFF",
          "useCase": "General information, tips, updates"
        }
      },
      "layout": {
        "position": "fixed",
        "bottom": "20px",
        "left": "20px",
        "right": "20px",
        "maxWidth": "400px",
        "alignSelf": "center",
        "zIndex": 1000
      },
      "styling": {
        "container": {
          "flexDirection": "row",
          "alignItems": "center",
          "justifyContent": "space-between",
          "paddingHorizontal": 16,
          "paddingVertical": 12,
          "borderRadius": 8,
          "borderWidth": 1,
          "shadowColor": "#000",
          "shadowOffset": { "width": 0, "height": 2 },
          "shadowOpacity": 0.25,
          "shadowRadius": 3.84,
          "elevation": 5
        },
        "content": {
          "flex": 1,
          "flexDirection": "row",
          "alignItems": "center"
        },
        "icon": {
          "marginRight": 8,
          "size": 20
        },
        "message": {
          "fontSize": 14,
          "fontWeight": "500",
          "color": "#FFFFFF",
          "flex": 1
        },
        "actions": {
          "flexDirection": "row",
          "alignItems": "center",
          "marginLeft": 12
        },
        "actionButton": {
          "marginRight": 8,
          "paddingHorizontal": 8,
          "paddingVertical": 4,
          "borderRadius": 4,
          "backgroundColor": "rgba(255, 255, 255, 0.2)"
        },
        "actionText": {
          "color": "#FFFFFF",
          "fontSize": 12,
          "fontWeight": "600"
        },
        "closeButton": {
          "padding": 4
        }
      },
      "animation": {
        "type": "spring",
        "show": {
          "toValue": 1,
          "useNativeDriver": true,
          "tension": 100,
          "friction": 8,
          "transform": {
            "translateY": {
              "inputRange": [0, 1],
              "outputRange": [100, 0]
            }
          }
        },
        "hide": {
          "toValue": 0,
          "useNativeDriver": true,
          "tension": 100,
          "friction": 8
        }
      },
      "behavior": {
        "autoHide": true,
        "defaultDuration": 4000,
        "dismissible": true,
        "actionButtons": "optional",
        "stacking": "single instance"
      },
      "props": {
        "visible": "boolean - Controls snackbar visibility",
        "message": "string - The notification message",
        "type": "SnackbarType - success | error | warning | info",
        "duration": "number - Auto-hide duration in milliseconds",
        "onClose": "() => void - Callback when snackbar is dismissed",
        "action": "optional object with label and onPress for action button"
      },
      "usage": {
        "context": "useSnackbar hook",
        "showSnackbar": "(message, type, duration, action) => void",
        "hideSnackbar": "() => void",
        "snackbar": "Current snackbar state object"
      },
      "integration": {
        "errorHandling": "Supabase error handler integration",
        "authErrors": "Authentication error notifications",
        "noteOperations": "Note CRUD operation feedback",
        "webOnly": "Platform.OS === 'web' conditional rendering"
      },
      "errorHandling": {
        "supabaseErrors": "Comprehensive Supabase error mapping",
        "userMessages": "User-friendly error messages",
        "retryLogic": "Retryable vs non-retryable errors",
        "networkErrors": "Network connectivity issues",
        "timeoutErrors": "Request timeout handling"
      }
    }
  },
